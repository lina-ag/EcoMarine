<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="app.HomeController"
      alignment="CENTER" spacing="20" style="-fx-padding: 30;">

    <Label text="Eco-Cleaning" style="-fx-font-size: 28; -fx-font-weight: bold;"/>
    <Label text="Accueil" style="-fx-font-size: 16;"/>

    <Button text="Entrer (Actions / Volontaires)"
            prefWidth="320" prefHeight="55"

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.BiodiversiteFormController"
      stylesheets="@../css/app.css"
      spacing="14" prefWidth="450">

    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <Label fx:id="lblTitle" text="Ajouter Observation" styleClass="page-title"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Espèce :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="tfEspece" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Zone :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="tfZone" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Nombre :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="tfNombre" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Date :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="tfDate" promptText="2026-03-11" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#annuler" styleClass="btn-secondary"/>
        <Button fx:id="btnSave" text="Ajouter" onAction="#save" styleClass="btn-primary"/>
    </HBox>
</VBox>
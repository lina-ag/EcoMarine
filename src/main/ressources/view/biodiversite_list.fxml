<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.BiodiversiteListController"
      stylesheets="@../css/app.css"
      styleClass="page"
      spacing="14">

    <HBox spacing="12" styleClass="topbar" alignment="CENTER_LEFT">
        <padding>
            <Insets top="14" right="16" bottom="14" left="16"/>
        </padding>

        <Label text="🐢 Biodiversité" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕ Ajouter Observation" onAction="#openAddForm" styleClass="btn-primary"/>
        <Button text="⟳ Actualiser" onAction="#refresh" styleClass="btn-secondary"/>
    </HBox>

    <VBox styleClass="card-panel" spacing="12" VBox.vgrow="ALWAYS">
        <Label text="Suivi des espèces marines observées dans les zones surveillées." styleClass="muted"/>

        <TextField fx:id="tfFiltre"
                   promptText="Filtrer par espèce, zone, date ou nombre..."
                   onKeyReleased="#filterBiodiversite"/>

        <TableView fx:id="tableBiodiversite" styleClass="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
                <TableColumn fx:id="colEspece" text="Espèce" prefWidth="220"/>
                <TableColumn fx:id="colZone" text="Zone" prefWidth="220"/>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="120"/>
                <TableColumn fx:id="colDate" text="Date" prefWidth="180"/>
                <TableColumn fx:id="colModifier" text="Modifier" prefWidth="120"/>
                <TableColumn fx:id="colSupprimer" text="Supprimer" prefWidth="120"/>
            </columns>
        </TableView>
    </VBox>
</VBox>
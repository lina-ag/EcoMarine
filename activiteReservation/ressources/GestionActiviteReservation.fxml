<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.GestionActiviteReservation"
            stylesheets="@style.css"
            styleClass="root-pane"
            prefWidth="1535"
            prefHeight="840">

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="12" prefWidth="260" styleClass="sidebar">

            <!-- Replace this entire StackPane -->
<StackPane alignment="CENTER">
    <Region styleClass="header-background"/>
    <Label text="🌊" style="-fx-font-size: 80px;"/>
</StackPane>

            <Label text="ECOMARINE" styleClass="sidebar-title" style="-fx-font-size: 20px; -fx-font-weight: none; -fx-text-fill: white;"/>
            <Label text="Gestion Touristique" styleClass="sidebar-subtitle" style="-fx-font-size: 16px; -fx-font-weight: none; -fx-text-fill: white;"/>


            <!-- ACTIVITES -->
            <Label text="ACTIVITÉS" styleClass="sidebar-section-label" style="-fx-font-size: 16px; -fx-font-weight: none; -fx-text-fill: white;"/>

            <HBox>
                <Button fx:id="btnBack" text="← Retour" styleClass="btn-back" onAction="#handleBack" />
            </HBox>

   
            <Button text="➕ Ajouter Activité"
                    onAction="#ouvrirAjouterActivite"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"/>

            <Button text="📋 Liste Activités"
                    onAction="#ouvrirAfficherActivites"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"/>
            <Button text="📅 Calendrier"
                    onAction="#ouvrirCalendrier"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"/>

            <!-- RESERVATIONS -->
            <Label text="RÉSERVATIONS"
                   styleClass="sidebar-section-label"
                   style="-fx-font-size: 16px; -fx-font-weight: none; -fx-text-fill: white;">
                <VBox.margin>
                    <Insets top="15"/>
                </VBox.margin>
            </Label>

          

            <Button text="➕ Ajouter Réservation"
                    onAction="#ouvrirAjouterReservation"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"/>
             

            <Button text="📋 Liste Réservations"
                    onAction="#ouvrirAfficherReservation"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"/>

           

            <Region VBox.vgrow="ALWAYS"/>

            <Separator styleClass="sidebar-separator"/>

            <!-- STATS -->
            <HBox spacing="20" alignment="CENTER" styleClass="stats-container">
                <VBox alignment="CENTER">
                    <Label fx:id="activitesCount" text="0" styleClass="stats-number" style="-fx-font-size: 26px; -fx-font-weight: none; -fx-text-fill: white;"/>
                    <Label text="Activités" styleClass="stats-label" style="-fx-font-size: 14px; -fx-font-weight: none; -fx-text-fill: white;"/>
                </VBox>
                <VBox alignment="CENTER">
                    <Label fx:id="reservationsCount" text="0" styleClass="stats-number" style="-fx-font-size: 26px; -fx-font-weight: none; -fx-text-fill: white;"/>
                    <Label text="Réservations" styleClass="stats-label" style="-fx-font-size: 14px; -fx-font-weight: none; -fx-text-fill: white;"/>
                </VBox>
            </HBox>

        </VBox>
    </left>

    <!-- CONTENU -->
    <center>
        <StackPane fx:id="mainContent" styleClass="root-pane"/>
    </center>

</BorderPane>
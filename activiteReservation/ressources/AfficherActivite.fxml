<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/18.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AfficherActivite"
            prefWidth="1535"
            prefHeight="840"
            stylesheets="@style.css"
            styleClass="root-pane">

    <children>
        <VBox spacing="20"
              style="-fx-background-color: white;
                     -fx-background-radius: 25;
                     -fx-border-radius: 25;
                     -fx-border-color: rgba(0,0,0,0.08);
                     -fx-border-width: 1.5;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0.15, 0, 5);"
              AnchorPane.topAnchor="25"
              AnchorPane.bottomAnchor="25"
              AnchorPane.leftAnchor="25"
              AnchorPane.rightAnchor="25">

            <padding>
                <Insets top="25" right="25" bottom="25" left="25" />
            </padding>

            <!-- Bouton Retour -->
            <Button fx:id="btnBack" text="← Retour" styleClass="btn-back" onAction="#handleBack" />

            <!-- Titre amélioré -->
            <Label text="📋 Liste des Activités" 
                   style="-fx-font-size: 26px; 
                          -fx-font-weight: bold;
                          -fx-text-fill: #1e3c72;
                          -fx-border-color: transparent transparent #1e3c72 transparent;
                          -fx-border-width: 0 0 2 0;
                          -fx-padding: 0 0 10 0;"
                   styleClass="page-title"/>

            <!-- Barre de recherche améliorée AVEC MICROPHONE -->
            <HBox spacing="15" alignment="CENTER" maxWidth="900">
                <TextField fx:id="searchField" 
                           promptText="🔍 Rechercher par nom, description, date..." 
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-radius: 20;
                                  -fx-border-radius: 20;
                                  -fx-border-color: #e0e0e0;
                                  -fx-border-width: 1.5;
                                  -fx-background-color: #f8f9fa;
                                  -fx-padding: 10 15;
                                  -fx-font-size: 13px;
                                  -fx-focus-color: #1e3c72;
                                  -fx-faint-focus-color: transparent;">
                    <HBox.margin>
                        <Insets left="10" right="10"/>
                    </HBox.margin>
                </TextField>
                
                <!-- BOUTON MICROPHONE -->
                <Button fx:id="microphoneButton" 
                        text="🎤" 
                        onAction="#rechercheVocale"
                        style="-fx-background-color: #ef4444; 
                               -fx-text-fill: white; 
                               -fx-background-radius: 25; 
                               -fx-min-width: 45; 
                               -fx-min-height: 45; 
                               -fx-font-size: 20px; 
                               -fx-cursor: hand;"/>
                
                <Button fx:id="searchButton" 
                        text="🔍 Rechercher" 
                        onAction="#handleSearch"
                        style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #0f2b4f);
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 20;
                               -fx-padding: 8 20;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, #1e3c72, 8, 0.2, 0, 2);"
                        styleClass="btn-search"/>
                        
                <Button fx:id="clearButton" 
                        text="✖ Effacer" 
                        onAction="#clearSearch"
                        style="-fx-background-color: #6c757d;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 20;
                               -fx-padding: 8 20;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, #6c757d, 8, 0.2, 0, 2);"
                        styleClass="btn-clear"/>
            </HBox>

            <!-- Filtres rapides améliorés -->
            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 5 0;">
                <Label text="Filtres rapides:" 
                       style="-fx-font-size: 13px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1e3c72;"
                       styleClass="filter-label"/>
                <Button text="Aujourd'hui" 
                        onAction="#filterToday" 
                        style="-fx-background-color: #e8f0fe;
                               -fx-text-fill: #1e3c72;
                               -fx-font-weight: bold;
                               -fx-background-radius: 15;
                               -fx-padding: 5 15;
                               -fx-cursor: hand;"
                        styleClass="btn-filter"/>
                <Button text="Cette semaine" 
                        onAction="#filterThisWeek" 
                        style="-fx-background-color: #e8f0fe;
                               -fx-text-fill: #1e3c72;
                               -fx-font-weight: bold;
                               -fx-background-radius: 15;
                               -fx-padding: 5 15;
                               -fx-cursor: hand;"
                        styleClass="btn-filter"/>
                <Button text="Ce mois" 
                        onAction="#filterThisMonth" 
                        style="-fx-background-color: #e8f0fe;
                               -fx-text-fill: #1e3c72;
                               -fx-font-weight: bold;
                               -fx-background-radius: 15;
                               -fx-padding: 5 15;
                               -fx-cursor: hand;"
                        styleClass="btn-filter"/>
                <Button text="Capacité > 10" 
                        onAction="#filterCapacity" 
                        style="-fx-background-color: #e8f0fe;
                               -fx-text-fill: #1e3c72;
                               -fx-font-weight: bold;
                               -fx-background-radius: 15;
                               -fx-padding: 5 15;
                               -fx-cursor: hand;"
                        styleClass="btn-filter"/>
            </HBox>

            <!-- Label pour le nombre de résultats -->
            <HBox alignment="CENTER_RIGHT">
                <Label fx:id="resultCountLabel" 
                       text="0 activité(s) trouvée(s)" 
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #666666;
                              -fx-font-weight: bold;"
                       styleClass="result-count"/>
            </HBox>

            <!-- Tableau des activités amélioré -->
            <TableView fx:id="tableActivite" 
                       prefHeight="450" 
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-radius: 15;
                              -fx-border-radius: 15;
                              -fx-border-color: #e0e0e0;
                              -fx-border-width: 1;
                              -fx-background-color: white;"
                       styleClass="activities-table">
                <columns>
                    <TableColumn fx:id="colId" 
                                 text="ID" 
                                 prefWidth="50"
                                 style="-fx-alignment: CENTER;
                                        -fx-font-weight: bold;"/>
                    <TableColumn fx:id="colNom" 
                                 text="Nom" 
                                 prefWidth="200"
                                 style="-fx-alignment: CENTER_LEFT;
                                        -fx-font-size: 13px;"/>
                    <TableColumn fx:id="colDescription" 
                                 text="Description" 
                                 prefWidth="300"
                                 style="-fx-alignment: CENTER_LEFT;
                                        -fx-font-size: 13px;"/>
                    <TableColumn fx:id="colDate" 
                                 text="Date" 
                                 prefWidth="120"
                                 style="-fx-alignment: CENTER;
                                        -fx-font-size: 13px;"/>
                    <TableColumn fx:id="colCapacite" 
                                 text="Capacité" 
                                 prefWidth="100"
                                 style="-fx-alignment: CENTER;
                                        -fx-font-size: 13px;"/>
                    <TableColumn fx:id="colModifier" 
                                 text="Modifier" 
                                 prefWidth="120"
                                 style="-fx-alignment: CENTER;
                                        -fx-font-size: 13px;"/>
                    <TableColumn fx:id="colSupprimer" 
                                 text="Supprimer" 
                                 prefWidth="120"
                                 style="-fx-alignment: CENTER;
                                        -fx-font-size: 13px;"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <!-- Bouton Ajouter amélioré -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="➕ Ajouter Nouvelle Activité" 
                        onAction="#handleAjouter"
                        style="-fx-background-color: linear-gradient(to bottom, #28a745, #218838);
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14px;
                               -fx-background-radius: 15;
                               -fx-padding: 10 25;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, #28a745, 10, 0.2, 0, 3);"
                        styleClass="btn-add"/>
            </HBox>

        </VBox>
    </children>

</AnchorPane>
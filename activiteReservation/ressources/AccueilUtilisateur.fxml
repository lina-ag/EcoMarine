<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AccueilUtilisateur"
            stylesheets="@style-accueil.css"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
           styleClass="root-pane" 
            prefWidth="1500"
            prefHeight="850"
           >
        
 <Pane fx:id="orb1" layoutX="50" layoutY="80" prefWidth="400" prefHeight="400" 
      style="-fx-background-color: rgba(126, 216, 192, 0.4); -fx-background-radius: 50%;"/>
<Pane fx:id="orb2" layoutX="850" layoutY="350" prefWidth="300" prefHeight="300" 
      style="-fx-background-color: rgba(8, 145, 178, 0.35); -fx-background-radius: 50%;"/>
<Pane fx:id="orb3" layoutX="700" layoutY="50" prefWidth="250" prefHeight="250" 
      style="-fx-background-color: rgba(15, 118, 110, 0.3); -fx-background-radius: 50%;"/>
<Pane fx:id="orb4" layoutX="1000" layoutY="550" prefWidth="500" prefHeight="500" 
      style="-fx-background-color: rgba(91, 155, 138, 0.25); -fx-background-radius: 50%;"/>
<Pane fx:id="orb5" layoutX="250" layoutY="500" prefWidth="350" prefHeight="350" 
      style="-fx-background-color: rgba(20, 184, 166, 0.3); -fx-background-radius: 50%;"/>
    <VBox styleClass="main-container" spacing="0">

        <!-- ═══════════════════════════════════════
             BARRE DE NAVIGATION
        ═══════════════════════════════════════ -->
        <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="12">

            <!-- Logo -->
            <VBox alignment="CENTER_LEFT" spacing="1">
                <Label styleClass="nav-logo-text" text="🌊 EcoMarine" />
                <Label styleClass="nav-logo-sub" text="Kuriat Island – Écotourisme &amp; Recherche" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Utilisateur connecté -->
            <Label fx:id="labelNomUtilisateur" styleClass="nav-user-label" text="👤 Bienvenue," />

            <!-- Déconnexion -->
            <Button fx:id="btnDeconnexion"
                    styleClass="btn-logout"
                    text="⏏  Déconnexion"
                    onAction="#handleDeconnexion" />
        </HBox>

        <!-- ═══════════════════════════════════════
             HERO + MÉTÉO
        ═══════════════════════════════════════ -->
        <HBox styleClass="hero-section" alignment="CENTER" spacing="50">

            <!-- Texte Hero -->
            <VBox alignment="CENTER_LEFT" spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="hero-title" text="Explorez" />
                    <Label styleClass="hero-title-accent" text="Kuriat Island" />
                </HBox>
                <Label styleClass="hero-subtitle"
                       text="Réservez vos activités écotouristiques, consultez votre calendrier et planifiez votre aventure marine." />
                <Label styleClass="hero-wave" text="🐢  🐠  🦀  🪸" />
            </VBox>

            <!-- ── CARTE MÉTÉO ── -->
            <VBox styleClass="weather-card" spacing="10" alignment="TOP_CENTER">

                <!-- En-tête -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label styleClass="weather-title" text="📍 MÉTÉO EN DIRECT" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnRefreshMeteo"
                            styleClass="weather-refresh-btn"
                            text="↻"
                            onAction="#handleRefreshMeteo" />
                </HBox>

                <Label fx:id="labelVille" styleClass="weather-location" text="Monastir, TN" />

                <!-- Séparateur -->
                <Region styleClass="weather-separator" />

                <!-- Icône + Température -->
                <HBox alignment="CENTER" spacing="16">
                    <Label fx:id="labelMeteoIcone" styleClass="weather-icon" text="🌊" />
                    <VBox alignment="CENTER_LEFT" spacing="2">
                        <Label fx:id="labelTemperature" styleClass="weather-temp" text="--°C" />
                        <Label fx:id="labelDescription" styleClass="weather-desc" text="Chargement…" />
                    </VBox>
                </HBox>

                <!-- Séparateur -->
                <Region styleClass="weather-separator" />

                <!-- Détails -->
                <GridPane hgap="20" vgap="6">
                    <Label text="💧 Humidité"   styleClass="weather-detail-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="labelHumidite" styleClass="weather-detail-value" text="--%" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="💨 Vent"        styleClass="weather-detail-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="labelVent"     styleClass="weather-detail-value" text="-- km/h" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="🌡 Ressenti"    styleClass="weather-detail-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="labelRessenti" styleClass="weather-detail-value" text="--°C" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>

                <Label fx:id="labelMeteoStatus" styleClass="weather-loading" text="Actualisation…" />
            </VBox>
        </HBox>

        <!-- ═══════════════════════════════════════
             GRILLE DES ACTIONS
        ═══════════════════════════════════════ -->
        <GridPane styleClass="actions-grid"
                  alignment="CENTER"
                  hgap="22" vgap="22"
                  VBox.vgrow="ALWAYS">

            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="200" prefWidth="220" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="200" prefWidth="220" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="200" prefWidth="220" />
            </columnConstraints>

            <!-- ── Carte 1 : Nouvelle Réservation ── -->
            <VBox styleClass="action-card, action-card-violet"
                  alignment="CENTER" spacing="10"
                  GridPane.columnIndex="0" GridPane.rowIndex="0"
                  onMouseClicked="#handleNouvelleReservation">
                <Label styleClass="action-icon" text="🏖️" />
                <VBox alignment="CENTER" spacing="4">
                    <Label styleClass="action-title" text="Nouvelle Réservation" />
                    <Label styleClass="action-desc" text="Réservez une activité écotouristique sur Kuriat Island" />
                </VBox>
                <Button styleClass="btn-reserve-main"
                        text="+ Réserver"
                        onAction="#handleNouvelleReservation" />
            </VBox>

         

            <!-- ── Carte 3 : Calendrier ── -->
            <VBox styleClass="action-card, action-card-green"
                  alignment="CENTER" spacing="10"
                  GridPane.columnIndex="2" GridPane.rowIndex="0"
                  onMouseClicked="#handleCalendrier">
                <Label styleClass="action-icon" text="📅" />
                <VBox alignment="CENTER" spacing="4">
                    <Label styleClass="action-title" text="Mon Calendrier" />
                    <Label styleClass="action-desc" text="Visualisez vos réservations sur le calendrier interactif" />
                </VBox>
            </VBox>

           

            <!-- ── Carte 5 : Profil ── -->
            <VBox styleClass="action-card, action-card-coral"
                  alignment="CENTER" spacing="10"
                  GridPane.columnIndex="0" GridPane.rowIndex="1"
                  onMouseClicked="#handleProfil">
                <Label styleClass="action-icon" text="👤" />
                <VBox alignment="CENTER" spacing="4">
                    <Label styleClass="action-title" text="Mon Profil" />
                    <Label styleClass="action-desc" text="Gérez vos informations personnelles et préférences" />
                </VBox>
            </VBox>

            <!-- ── Carte 6 : À propos de Kuriat ── -->
            <VBox styleClass="action-card"
                  alignment="CENTER" spacing="10"
                  GridPane.columnIndex="2" GridPane.rowIndex="1"
                  onMouseClicked="#handleAPropos">
                <Label styleClass="action-icon" text="🐢" />
                <VBox alignment="CENTER" spacing="4">
                    <Label styleClass="action-title" text="Kuriat Island" />
                    <Label styleClass="action-desc" text="En savoir plus sur l'île et sa biodiversité marine" />
                </VBox>
            </VBox>

        </GridPane>

        <!-- ═══════════════════════════════════════
             BANDE STATISTIQUES
        ═══════════════════════════════════════ -->
        <HBox styleClass="info-band" alignment="CENTER" spacing="0">
            <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="info-stat-value" text="🐢 120+" />
                <Label styleClass="info-stat-label" text="Tortues caouannes" />
            </VBox>
            <Region styleClass="info-divider" />
            <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="info-stat-value" text="🤿 8" />
                <Label styleClass="info-stat-label" text="Activités disponibles" />
            </VBox>
            <Region styleClass="info-divider" />
            <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="info-stat-value" text="🌊 4 km²" />
                <Label styleClass="info-stat-label" text="Surface de l'île" />
            </VBox>
            <Region styleClass="info-divider" />
            <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                <Label styleClass="info-stat-value" text="📍 Monastir" />
                <Label styleClass="info-stat-label" text="Tunisie" />
            </VBox>
        </HBox>

        <!-- ═══════════════════════════════════════
             FOOTER
        ═══════════════════════════════════════ -->
        <HBox styleClass="footer-bar" alignment="CENTER">
            <Label styleClass="footer-text"
                   text="© 2025 EcoMarine – Écotourisme &amp; Recherche scientifique | Kuriat Island, Monastir, Tunisie" />
        </HBox>

    </VBox>
</ScrollPane>

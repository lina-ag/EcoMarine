<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<AnchorPane xmlns="http://javafx.com/javafx/18.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AccueilUtilisateur"
            prefWidth="1300"
            prefHeight="800"
            stylesheets="@style-accueil.css"
            styleClass="root-pane">

   
    
    <!-- ORBS DÉCORATIFS (remis) -->
    <Pane mouseTransparent="true" style="-fx-background-color: transparent;">
        <Circle fx:id="orb1" radius="280" fill="#7ed8c0" 
                layoutX="150" layoutY="200" opacity="0.25"/>
        <Circle fx:id="orb2" radius="200" fill="#0891b2" 
                layoutX="1050" layoutY="500" opacity="0.2"/>
        <Circle fx:id="orb3" radius="150" fill="#0f766e" 
                layoutX="900" layoutY="150" opacity="0.2"/>
        <Circle fx:id="orb4" radius="320" fill="#5b9b8a" 
                layoutX="1300" layoutY="700" opacity="0.15"/>
    </Pane>

    <!-- CONTENU PRINCIPAL - PLEINE LARGEUR -->
    <VBox fx:id="mainVBox" spacing="0" alignment="TOP_CENTER" 
          style="-fx-background-color: transparent; -fx-padding: 0;">

        <!-- TOP BAR - TRANSPARENT -->
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <Label styleClass="logo-icon" text="🌊"/>
                <VBox spacing="1">
                    <Label styleClass="logo-title" text="EcoMarine"/>
                    <Label styleClass="logo-subtitle" text="KURIAT ISLAND · MONASTIR"/>
                </VBox>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox styleClass="mode-badge" alignment="CENTER" spacing="10">
                <Circle styleClass="mode-dot" radius="5" fill="#7ed8c0"/>
                <Label styleClass="mode-text" text="Mode Visiteur"/>
            </HBox>
        </HBox>

        <!-- HERO SECTION -->
        <VBox styleClass="hero-section" alignment="CENTER" spacing="12">
            <Label styleClass="hero-eyebrow" text="BIENVENUE SUR LA PLATEFORME"/>
            <Label styleClass="hero-title" text="Explorez l'île Kuriat"/>
            <Label styleClass="hero-desc" text="Découvrez nos activités écotouristiques, réservez votre expérience et partez à la rencontre de la faune marine méditerranéenne."
                   wrapText="true"/>
        </VBox>

        <!-- GRILLE CARTES - 4 COLONNES -->
        <GridPane fx:id="cardsGrid" styleClass="cards-grid" hgap="24" vgap="24" 
                  GridPane.hgrow="ALWAYS" maxWidth="Infinity">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
            </columnConstraints>
            
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS"/>
            </rowConstraints>

            <!-- Carte 1 - Activités -->
            <VBox fx:id="cardActivites" styleClass="card" spacing="10" onMouseClicked="#ouvrirActivites"
                  GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label styleClass="card-icon" text="🐠"/>
                <Label styleClass="card-title" text="Activités"/>
                <Label styleClass="card-desc" text="Plongée, snorkeling, observation des tortues" wrapText="true"/>
                <Label styleClass="card-link" text="Voir les activités →"/>
            </VBox>

            <!-- Carte 2 - Réservations -->
            <VBox fx:id="cardReservations" styleClass="card" spacing="10" onMouseClicked="#ouvrirReservations"
                  GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label styleClass="card-icon" text="📅"/>
                <Label styleClass="card-title" text="Réservations"/>
                <Label styleClass="card-desc" text="Consultez et gérez vos réservations" wrapText="true"/>
                <Label styleClass="card-link" text="Voir mes réservations →"/>
            </VBox>

            <!-- Carte 3 - À propos -->
            <VBox fx:id="cardAPropos" styleClass="card" spacing="10" onMouseClicked="#ouvrirAPropos"
                  GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label styleClass="card-icon" text="🌍"/>
                <Label styleClass="card-title" text="À propos"/>
                <Label styleClass="card-desc" text="L'île Kuriat et notre mission écologique" wrapText="true"/>
                <Label styleClass="card-link" text="En savoir plus →"/>
            </VBox>

            <!-- Carte 4 - Statistiques verrouillée -->
            <StackPane GridPane.columnIndex="3" GridPane.rowIndex="0">
                <VBox styleClass="card-locked" spacing="10">
                    <Label styleClass="card-icon" text="🔒"/>
                    <Label styleClass="card-title" text="Statistiques"/>
                    <Label styleClass="card-desc" text="Tableau de bord &amp; indicateurs KPI" wrapText="true"/>
                    <Label styleClass="card-link" text="Non disponible pour les visiteurs"/>
                </VBox>
                <Label styleClass="restricted-badge" text="ACCÈS RESTREINT" StackPane.alignment="TOP_RIGHT"/>
            </StackPane>
        </GridPane>

        <!-- ISLAND STRIP -->
        <HBox fx:id="islandStrip" styleClass="island-strip" alignment="CENTER_LEFT" spacing="18"
              maxWidth="Infinity">
            <VBox.margin><Insets left="40" right="40" bottom="20" top="20"/></VBox.margin>
            <Label styleClass="island-icon" text="🏝"/>
            <VBox spacing="5">
                <Label styleClass="island-title" text="Îles Kuriat · Monastir, Tunisie"/>
                <Label styleClass="island-desc" text="Site naturel protégé — Refuge des tortues Caretta caretta en Méditerranée" wrapText="true"/>
            </VBox>
        </HBox>

        <!-- CTA BOUTON -->
        <VBox styleClass="cta-container" alignment="CENTER">
            <Button fx:id="btnReserver" styleClass="btn-primary" text="🌊   Réserver une activité"
                    onAction="#ouvrirReservations" maxWidth="Infinity"/>
        </VBox>

    </VBox>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.AccueilUtilisateur"
           stylesheets="@style-accueil.css"
           prefWidth="1500" prefHeight="800">

    <!-- Fond dégradé océan -->
    <VBox styleClass="ocean-bg"/>

    <!-- Orbes décoratives -->
    <Region styleClass="orb-top-right"/>
    <Region styleClass="orb-bottom-left"/>

    <!-- Carte centrale -->
    <VBox alignment="CENTER">
        <VBox styleClass="glass-card" alignment="CENTER" spacing="0" maxWidth="460">

            <!-- Icône -->
            <StackPane styleClass="icon-circle">
                <StackPane alignment="CENTER">
                <Region styleClass="header-background"/>
                <ImageView fitWidth="120" fitHeight="120" preserveRatio="true">
                    <Image url="file:/C:/Users/WSI/Downloads/logoEco.png"/>
                </ImageView>
            </StackPane>
            </StackPane>

            <!-- Label "Espace personnel" -->
            <Label text="ESPACE UTILISATEUR" styleClass="section-tag">
                <VBox.margin><Insets top="20"/></VBox.margin>
            </Label>

            <!-- Nom utilisateur -->
            <Label fx:id="lblNomUtilisateur" text="Bienvenue !" styleClass="user-name">
                <VBox.margin><Insets top="8"/></VBox.margin>
            </Label>

            <!-- Date badge -->
            <HBox styleClass="date-badge" alignment="CENTER" spacing="8">
                <Label text="📅" style="-fx-font-size: 13px;"/>
                <Label fx:id="lblDateActuelle" text="Date" styleClass="date-text"/>
                <VBox.margin><Insets top="14" bottom="20"/></VBox.margin>
            </HBox>

            <!-- Séparateur -->
            <Region styleClass="glass-separator" maxWidth="320">
                <VBox.margin><Insets bottom="24"/></VBox.margin>
            </Region>

            <!-- Bouton primaire -->
            <Button fx:id="btnAjouterReservation"
                    text="＋   Ajouter une réservation"
                    onAction="#ouvrirAjouterReservation"
                    maxWidth="Infinity"
                    styleClass="btn-ocean-primary">
                <VBox.margin><Insets bottom="12"/></VBox.margin>
            </Button>

            <!-- Bouton secondaire -->
            <Button fx:id="btnCalendrier"
                    text="📅   Consulter le calendrier"
                    onAction="#ouvrirCalendrier"
                    maxWidth="Infinity"
                    styleClass="btn-ocean-secondary"/>

            <!-- Stats rapides -->
            <HBox alignment="CENTER" spacing="36" styleClass="stats-row">
                <VBox alignment="CENTER" spacing="3">
                    <Label fx:id="lblNbReservations" text="—" styleClass="stat-number"/>
                    <Label text="RÉSERVATIONS" styleClass="stat-label"/>
                </VBox>
                <Region styleClass="stat-divider"/>
                <VBox alignment="CENTER" spacing="3">
                    <Label fx:id="lblNbActivites" text="—" styleClass="stat-number"/>
                    <Label text="ACTIVITÉS" styleClass="stat-label"/>
                </VBox>
                <Region styleClass="stat-divider"/>
                <VBox alignment="CENTER" spacing="3">
                    <Label text="2026" styleClass="stat-number"/>
                    <Label text="SAISON" styleClass="stat-label"/>
                </VBox>
                <VBox.margin><Insets top="24"/></VBox.margin>
            </HBox>

            <!-- Footer -->
            <HBox alignment="CENTER" spacing="6" styleClass="card-footer">
                <Label text="EcoMarine" styleClass="footer-text"/>
                <Label text="•" styleClass="footer-dot"/>
                <Label text="Surveillance marine" styleClass="footer-text"/>
                <VBox.margin><Insets top="20"/></VBox.margin>
            </HBox>

        </VBox>
    </VBox>

</StackPane>
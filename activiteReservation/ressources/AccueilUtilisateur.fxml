<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.AccueilUtilisateur"
      spacing="25" 
      alignment="CENTER" 
      stylesheets="@style.css"
      styleClass="root-pane"
      style="-fx-background-color: linear-gradient(to bottom, #ecf0f1, #d5dbdb);"
      prefWidth="1500"
      prefHeight="800">

    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding> 

    <!-- Carte principale -->
    <VBox spacing="30"
          alignment="CENTER"
          style="-fx-background-color: white;
                 -fx-background-radius: 35;
                 -fx-border-radius: 35;
                 -fx-border-color: rgba(0,0,0,0.08);
                 -fx-border-width: 1.5;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 30, 0.2, 0, 10);
                 -fx-padding: 45 55 55 55;"
          maxWidth="550">

        <!-- Icône EcoMarine -->
        <Label text="🌊"
               style="-fx-font-size: 64px; 
                      -fx-padding: 0 0 5 0;"/>

        <!-- Nom de l'utilisateur -->
        <Label fx:id="lblNomUtilisateur" 
               text="Bienvenue !" 
               style="-fx-font-size: 28px; 
                      -fx-font-weight: bold;
                      -fx-text-fill: #1e3c72;
                      -fx-border-color: transparent transparent #1e3c72 transparent;
                      -fx-border-width: 0 0 2 0;
                      -fx-padding: 0 0 12 0;"/>

        <!-- Date actuelle -->
        <HBox spacing="8" alignment="CENTER">
            <Label text="📅"
                   style="-fx-font-size: 18px;"/>
            <Label fx:id="lblDateActuelle" 
                   text="Date" 
                   style="-fx-font-size: 15px; 
                          -fx-text-fill: #64748b;
                          -fx-font-weight: 500;"/>
        </HBox>

        <!-- Séparateur décoratif -->
        <Region style="-fx-background-color: #e0e0e0; 
                       -fx-min-height: 2; 
                       -fx-max-height: 2; 
                       -fx-min-width: 80; 
                       -fx-background-radius: 2;"/>

        <!-- Boutons -->
        <VBox spacing="18" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="btnAjouterReservation" 
                    text="➕  Ajouter une réservation" 
                    prefWidth="280"
                    prefHeight="52"
                    style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #0f2b4f);
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 15px;
                           -fx-background-radius: 30;
                           -fx-padding: 12 25;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, #1e3c72, 12, 0.3, 0, 4);" 
                    onAction="#ouvrirAjouterReservation"/>
            
            <Button fx:id="btnCalendrier" 
                    text="📅  Consulter le calendrier" 
                    prefWidth="280"
                    prefHeight="52"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #1e3c72;
                           -fx-font-weight: bold;
                           -fx-font-size: 15px;
                           -fx-border-color: #1e3c72;
                           -fx-border-width: 2;
                           -fx-border-radius: 30;
                           -fx-background-radius: 30;
                           -fx-padding: 12 25;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(30,60,114,0.15), 8, 0.2, 0, 2);" 
                    onAction="#ouvrirCalendrier"/>
        </VBox>

        <!-- Message d'information -->
        <HBox spacing="12" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
            <Label text="✨"
                   style="-fx-font-size: 12px;"/>
            <Label text="Gérez vos réservations facilement"
                   style="-fx-font-size: 11px; 
                          -fx-text-fill: #94a3b8;
                          -fx-font-style: italic;"/>
            <Label text="✨"
                   style="-fx-font-size: 12px;"/>
        </HBox>

    </VBox>

    <!-- Pied de page -->
    <HBox alignment="CENTER" spacing="8" style="-fx-padding: 25 0 0 0;">
        <Label text="🔊"
               style="-fx-font-size: 10px; -fx-text-fill: #cbd5e1;"/>
        <Label text="Recherche vocale disponible"
               style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;"/>
        <Label text="•"
               style="-fx-font-size: 10px; -fx-text-fill: #cbd5e1;"/>
        <Label text="EcoMarine"
               style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;"/>
    </HBox>

</VBox>
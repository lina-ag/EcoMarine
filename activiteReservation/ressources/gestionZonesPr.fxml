<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.GestionZonesPr"
            stylesheets="@style.css"
            styleClass="root-pane"
            prefWidth="1500"
            prefHeight="800">

   
   <left>
      <VBox spacing="10"
            prefWidth="260"
            styleClass="sidebar">
         
        
         <StackPane styleClass="sidebar-header">
            <Region styleClass="header-background" />
            <ImageView fitWidth="150"
                       fitHeight="150"
                       preserveRatio="true">
              <image>
                 <Image url="file:/C:/Users/WSI/Downloads/logoEco.png"/>
              </image>
            </ImageView>
         </StackPane>
         
        
         <Label text="ECOMARINE"
                styleClass="sidebar-title"
                style="-fx-text-fill: white;" />
         
         <Label text="Zone protégée"
                styleClass="sidebar-subtitle"
                style="-fx-text-fill: rgba(255,255,255,0.9);" />
         
         <Separator styleClass="sidebar-separator" />
         
         
         <Label text="PRINCIPAL"
                styleClass="sidebar-section-label"
                style="-fx-text-fill: rgba(255,255,255,0.7);" />
         
         <Button text="Ajouter Zone"
                 onAction="#ouvrirAjouter"
                 maxWidth="Infinity"
                 styleClass="sidebar-button">
            <graphic>
               <ImageView fitWidth="20"
                         fitHeight="20"
                         preserveRatio="true">
                 <image>
                    <Image url="file:/C:/Users/WSI/Downloads/zone.png"/>
                 </image>
              </ImageView>
            </graphic>
         </Button>

         <Button text="Liste des Zones"
                 onAction="#ouvrirAfficher"
                 maxWidth="Infinity"
                 styleClass="sidebar-button">
            <graphic>
               <ImageView fitWidth="20"
                         fitHeight="20"
                         preserveRatio="true">
                 <image>
                    <Image url="file:/C:/Users/WSI/Downloads/list.png"/>
                 </image>
              </ImageView>
            </graphic>
         </Button>
         <Button text="Recherche Vocale"
                 onAction="#ouvrirRechercheVocale"
                 maxWidth="Infinity"
                 styleClass="sidebar-button"/>
         
         
         <Label text="SURVEILLANCE"
                styleClass="sidebar-section-label"
                style="-fx-text-fill: rgba(255,255,255,0.7);">
            <VBox.margin>
               <Insets top="15" />
            </VBox.margin>
         </Label>

         <Button text="Voir Surveillance"
                 onAction="#ouvrirSurveillance"
                 maxWidth="Infinity"
                 styleClass="sidebar-button">
            <graphic>
              <ImageView fitWidth="20"
                         fitHeight="20"
                         preserveRatio="true">
                 <image>
                    <Image url="file:/C:/Users/WSI/Downloads/surv.png"/>
                 </image>
              </ImageView>
            </graphic>
         </Button>

         <Button text="Nouvelle Surveillance"
                 onAction="#ouvrirAjouterSurv"
                 maxWidth="Infinity"
                 styleClass="sidebar-button">
            <graphic>
               <ImageView fitWidth="20"
                         fitHeight="20"
                         preserveRatio="true">
                 <image>
                    <Image url="file:/C:/Users/WSI/Downloads/ajsurv.png"/>
                 </image>
              </ImageView>
            </graphic>
         
         </Button>
         
         
         
       
         <Separator styleClass="sidebar-separator" />
         
         <HBox spacing="10" alignment="CENTER" styleClass="stats-container">
            <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS">
               <Label fx:id="lblNbZones"
                      styleClass="stats-number"
                      style="-fx-text-fill: white;" />

              <Label text="Zones"
                      styleClass="stats-label"
                      style="-fx-text-fill: rgba(255,255,255,0.8);" />
            </VBox>
            <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS">
               <Label fx:id="lblNbSurv"
                      styleClass="stats-number"
                      style="-fx-text-fill: white;" />

              <Label text="Surveillances"
                      styleClass="stats-label"
                      style="-fx-text-fill: rgba(255,255,255,0.8);" />
            </VBox>
         </HBox>
         <Button text="🏠 Accueil"
                    onAction="#ouvrirAccueil"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"
                    />
         
         
         <Region VBox.vgrow="ALWAYS" />
         
      </VBox>
   </left>

  
   <center>
    <StackPane fx:id="centerPane">
        <VBox  spacing="30" style="-fx-padding: 40;">

            
            <VBox spacing="10"
                  style="-fx-background-color: white;
                         -fx-padding:10;
                         -fx-background-radius: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0.3, 0, 4);
                          
                          ">

                <HBox spacing="10" alignment="CENTER_LEFT">

                    <ImageView fitWidth="18"
                               fitHeight="18"
                               preserveRatio="true">
                       <image>
                          <Image url="file:/C:/Users/WSI/Downloads/alert.png"/>
                      </image>
                  </ImageView>

                 <Label text="Dernière activité"
                        style="-fx-font-size: 16px;
                              -fx-font-weight: bold;
                             -fx-text-fill: #333;" />

              </HBox>
                              

                <Label fx:id="lblDerniereZone"
                       style="-fx-text-fill: black;
                              -fx-font-size: 14px;" />

                <Label fx:id="lblDerniereSurv"
                       style="-fx-text-fill: black;
                              -fx-font-size: 14px;" />

            </VBox>


            
            <VBox alignment="CENTER" spacing="20">

                <Label text="Statistiques des Zones"
                       style="-fx-font-size: 26px;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;" />

                <PieChart fx:id="pieChart"
                          prefWidth="500"
                          prefHeight="400" />

            </VBox>


            
            <VBox alignment="CENTER"
                  spacing="10"
                  style="-fx-background-color: white;
                         -fx-padding: 15;
                         -fx-background-radius: 25;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0.3, 0, 4);">
                

                <HBox spacing="10" alignment="CENTER">

                    <ImageView fitWidth="30"
                               fitHeight="30"
                               preserveRatio="true">
                      <image>
                        <Image url="file:/C:/Users/WSI/Downloads/eco.png"/>
                     </image>
                  </ImageView>

                  <Label text="Indice ÉcoMarine"
                         style="-fx-font-size: 20px;
                                -fx-font-weight: bold;
                                -fx-text-fill: #333;" />

               </HBox>
                <Label fx:id="lblScoreEco"
                       style="-fx-font-size: 36px;
                              -fx-font-weight: bold;" />

            </VBox>

        </VBox>
    </StackPane>
</center>

</BorderPane> 
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.HomeController"
            prefWidth="1500"
            prefHeight="800"
            stylesheets="@style.css"
            styleClass="root-pane">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox alignment="CENTER" spacing="15">
            <padding>
                <Insets top="70" bottom="40"/>
            </padding>

            <Label text="Bienvenue sur EcoMarine"
                   style="-fx-font-size: 42px;
                          -fx-text-fill: white;
                          -fx-font-weight: bold;
                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0.5, 0, 2);" />

            <Label text="Plateforme de gestion intelligente"
                   style="-fx-font-size: 20px;
                          -fx-text-fill: rgba(255,255,255,0.9);
                          -fx-font-weight: 300;
                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 5, 0.3, 0, 1);" />
        </VBox>
    </top>


    <!-- ================= CENTER CARD ================= -->
    <center>
        <StackPane>
            <VBox spacing="30"
                  alignment="CENTER"
                  prefWidth="420"
                  maxWidth="420"
                  style="-fx-background-color: white;
                         -fx-padding: 50 50 60 50;
                         -fx-background-radius: 30;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 40, 0.3, 0, 10);
                         -fx-border-color: rgba(255,255,255,0.3);
                         -fx-border-width: 1;
                         -fx-border-radius: 30;">

                <Label text="Bienvenue"
                       style="-fx-font-size: 28px;
                              -fx-font-weight: 300;
                              -fx-text-fill: #1e3c72;
                              -fx-padding: 0 0 15 0;
                              -fx-border-color: transparent transparent #1e3c72 transparent;
                              -fx-border-width: 0 0 2 0;
                              -fx-border-style: segments(10, 10, 10, 10);" />

                <Label text="Connectez-vous ou créez un compte pour accéder à votre espace"
                       wrapText="true"
                       textAlignment="CENTER"
                       style="-fx-font-size: 14px;
                              -fx-text-fill: #666666;
                              -fx-padding: 0 0 10 0;" />

                <Button text="Se connecter"
                        prefHeight="55"
                        maxWidth="Infinity"
                        style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #0f2b4f);
                               -fx-text-fill: white;
                               -fx-font-size: 18px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 15;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, #1e3c72, 15, 0.3, 0, 5);"
                        onAction="#openSignIn"/>

                <Button text="Créer un compte"
                        prefHeight="55"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-border-color: #2a5298;
                               -fx-border-width: 2.5;
                               -fx-text-fill: #2a5298;
                               -fx-font-size: 18px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 15;
                               -fx-border-radius: 15;
                               -fx-cursor: hand;"
                        onAction="#openSignUp"/>

                <HBox alignment="CENTER" spacing="10">
                    <Label text="Déjà 1000+ utilisateurs"
                           style="-fx-font-size: 13px;
                                  -fx-text-fill: #888888;
                                  -fx-font-style: italic;"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>


   
    <bottom>
        <HBox alignment="CENTER">
            <padding>
                <Insets bottom="30"/>
            </padding>

            <Label text="© 2026 EcoMarine • Innovation Durable • Version 2.0"
                   style="-fx-text-fill: rgba(255,255,255,0.7);
                          -fx-font-size: 13px;
                          -fx-font-weight: 300;
                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 3, 0.2, 0, 1);" />
        </HBox>
    </bottom>

</BorderPane>
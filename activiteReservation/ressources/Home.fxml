<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.HomeController"
            prefWidth="600" prefHeight="400"
            stylesheets="@style.css"
            styleClass="root-pane"
            style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298);">
    
    <!-- Titre en haut -->
    <top>
        <VBox alignment="CENTER" spacing="10">
            <Label text="Bienvenue"
                   style="-fx-font-size: 36px; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label text="Choisissez une option"
                   style="-fx-font-size: 18px; -fx-text-fill: white;"/>
            <padding>
                <Insets top="40" bottom="20"/>
            </padding>
        </VBox>
    </top>
    
    <!-- Centre avec les boutons -->
    <center>
        <VBox spacing="20" 
              alignment="CENTER"
              maxWidth="300"
              style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, black, 10, 0.3, 0, 2);">
            
            <Button text="Sign In"
                    maxWidth="Infinity"
                    prefHeight="40"
                    style="-fx-background-color: #0f4c75; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 16px;"
                    onAction="#openSignIn" />
            
            <Button text="Sign Up"
                    maxWidth="Infinity"
                    prefHeight="40"
                    style="-fx-background-color: #3282b8; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 16px;"
                    onAction="#openSignUp" />
        </VBox>
    </center>
    
    <!-- Pour centrer le contenu du centre -->
    <padding>
        <Insets left="20" right="20" bottom="20"/>
    </padding>
</BorderPane>
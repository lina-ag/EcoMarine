<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.AjouterSurveillance"
      spacing="15"
      alignment="CENTER"
      prefWidth="400"
      prefHeight="350"
      style="-fx-padding: 20;"
      stylesheets="@style.css">

    <Label text="Ajouter Surveillance"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <TextField fx:id="tfDate"
               promptText="Date (YYYY-MM-DD)" />

    <TextField fx:id="tfObservation"
               promptText="Observation" />

    <TextField fx:id="tfIdZone" 
               promptText="ID Zone" />

    <Button text="Ajouter"
            onAction="#ajouterSurveillance"
            style="-fx-background-color: linear-gradient(to bottom, #89CFF0, #4682B4);
                   -fx-text-fill: white;
                   -fx-font-weight: bold;" />

</VBox>
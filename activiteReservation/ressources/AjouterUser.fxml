<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.AjouterUser"
            prefWidth="1500" 
            prefHeight="800"
            stylesheets="@style.css"
            styleClass="root-pane">

    <children>
        <VBox spacing="15" 
              alignment="CENTER"
              style="-fx-background-color: white;
                     -fx-background-radius: 25;
                     -fx-border-radius: 25;
                     -fx-border-color: rgba(0,0,0,0.08);
                     -fx-border-width: 1.5;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 20, 0.15, 0, 5);
                     -fx-padding: 30 35 35 35;"
              AnchorPane.topAnchor="80"
              AnchorPane.bottomAnchor="80"
              AnchorPane.leftAnchor="450"
              AnchorPane.rightAnchor="450">

            <!-- Titre -->
            <Label text="👤 Ajouter un Utilisateur" 
                   style="-fx-font-size: 24px; 
                          -fx-font-weight: bold;
                          -fx-text-fill: #1e3c72;
                          -fx-border-color: transparent transparent #1e3c72 transparent;
                          -fx-border-width: 0 0 2 0;
                          -fx-padding: 0 0 8 0;"/>

            <!-- Nom -->
            <TextField fx:id="nomField" 
                       promptText="Nom"
                       style="-fx-background-radius: 10;
                              -fx-border-radius: 10;
                              -fx-border-color: #e0e0e0;
                              -fx-border-width: 1.2;
                              -fx-background-color: #f8f9fa;
                              -fx-padding: 10 12;
                              -fx-font-size: 13px;
                              -fx-focus-color: #1e3c72;
                              -fx-faint-focus-color: transparent;"
                       prefWidth="280"
                       maxWidth="Infinity"/>

            <!-- Prénom -->
            <TextField fx:id="prenomField" 
                       promptText="Prénom"
                       style="-fx-background-radius: 10;
                              -fx-border-radius: 10;
                              -fx-border-color: #e0e0e0;
                              -fx-border-width: 1.2;
                              -fx-background-color: #f8f9fa;
                              -fx-padding: 10 12;
                              -fx-font-size: 13px;
                              -fx-focus-color: #1e3c72;
                              -fx-faint-focus-color: transparent;"
                       prefWidth="280"
                       maxWidth="Infinity"/>

            <!-- Email -->
            <TextField fx:id="emailField" 
                       promptText="Email"
                       style="-fx-background-radius: 10;
                              -fx-border-radius: 10;
                              -fx-border-color: #e0e0e0;
                              -fx-border-width: 1.2;
                              -fx-background-color: #f8f9fa;
                              -fx-padding: 10 12;
                              -fx-font-size: 13px;
                              -fx-focus-color: #1e3c72;
                              -fx-faint-focus-color: transparent;"
                       prefWidth="280"
                       maxWidth="Infinity"/>

            <!-- Mot de passe -->
            <PasswordField fx:id="motDePasseField" 
                           promptText="Mot de passe"
                           style="-fx-background-radius: 10;
                                  -fx-border-radius: 10;
                                  -fx-border-color: #e0e0e0;
                                  -fx-border-width: 1.2;
                                  -fx-background-color: #f8f9fa;
                                  -fx-padding: 10 12;
                                  -fx-font-size: 13px;
                                  -fx-focus-color: #1e3c72;
                                  -fx-faint-focus-color: transparent;"
                           prefWidth="280"
                           maxWidth="Infinity"/>

            <!-- Téléphone -->
            <TextField fx:id="telephoneField" 
                       promptText="Téléphone"
                       style="-fx-background-radius: 10;
                              -fx-border-radius: 10;
                              -fx-border-color: #e0e0e0;
                              -fx-border-width: 1.2;
                              -fx-background-color: #f8f9fa;
                              -fx-padding: 10 12;
                              -fx-font-size: 13px;
                              -fx-focus-color: #1e3c72;
                              -fx-faint-focus-color: transparent;"
                       prefWidth="280"
                       maxWidth="Infinity"/>

            <!-- Rôle -->
            <ComboBox fx:id="roleCombo" 
                      promptText="Rôle"
                      prefWidth="280"
                      maxWidth="Infinity"
                      style="-fx-background-radius: 10;
                             -fx-border-radius: 10;
                             -fx-border-color: #e0e0e0;
                             -fx-border-width: 1.2;
                             -fx-background-color: #f8f9fa;
                             -fx-padding: 8 10;
                             -fx-font-size: 13px;
                             -fx-focus-color: #1e3c72;
                             -fx-faint-focus-color: transparent;"/>

            <!-- Date de naissance -->
            <DatePicker fx:id="dateNaissancePicker" 
                        promptText="Date de naissance"
                        prefWidth="280"
                        maxWidth="Infinity"
                        style="-fx-background-radius: 10;
                               -fx-border-radius: 10;
                               -fx-border-color: #e0e0e0;
                               -fx-border-width: 1.2;
                               -fx-background-color: #f8f9fa;
                               -fx-font-size: 13px;
                               -fx-focus-color: #1e3c72;
                               -fx-faint-focus-color: transparent;"/>

            <!-- Boutons -->
            <HBox spacing="15" alignment="CENTER" maxWidth="Infinity">
                <Button text="Ajouter" 
                        onAction="#ajouterUser" 
                        style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #0f2b4f);
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14px;
                               -fx-background-radius: 12;
                               -fx-padding: 8 20;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, #1e3c72, 8, 0.2, 0, 2);"
                        prefWidth="100"/>
                <Button text="Annuler" 
                        onAction="#annuler"
                        style="-fx-background-color: #6c757d;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 14px;
                               -fx-background-radius: 12;
                               -fx-padding: 8 20;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, #6c757d, 6, 0.2, 0, 2);"
                        prefWidth="100"/>
            </HBox>

        </VBox>
    </children>

</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ModifierReservation"
            prefWidth="500"
            prefHeight="450"
            stylesheets="@style.css">

    <children>
    <VBox spacing="10" padding="20">
    <!-- Bouton back tout en haut -->
    <HBox>
        <Button fx:id="btnBack" text="← Retour" styleClass="btn-back" onAction="#handleBack" />
    </HBox>

    <!-- Reste de ton contenu -->
    ...
</VBox>

        <VBox spacing="15"
              alignment="CENTER"
              AnchorPane.topAnchor="20"
              AnchorPane.bottomAnchor="20"
              AnchorPane.leftAnchor="40"
              AnchorPane.rightAnchor="40">

            <Label text="Modifier Réservation"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />

            <GridPane hgap="10" vgap="15">

                <Label text="ID :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="idField"
                           editable="false"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Nom :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="nomField"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <Label text="Email :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="emailField"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="1"/>

                <Label text="Nombre de personnes :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="nombre_personnesField"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="1"/>

                <Label text="Date :" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="dateField"
                           promptText="YYYY-MM-DD"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="1"/>

                <Label text="ID Activité :" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="idActiviteField"
                           GridPane.rowIndex="5"
                           GridPane.columnIndex="1"/>

            </GridPane>

            <HBox spacing="20" alignment="CENTER">

                <Button text="Modifier"
                        onAction="#modifierReservation"
                        style="-fx-background-color: #6a0dad; -fx-text-fill: white; -fx-font-weight: bold;"
                        prefWidth="120"/>

                <Button text="Annuler"
                        onAction="#annuler"
                        style="-fx-background-color: #a0a0a0; -fx-text-fill: white; -fx-font-weight: bold;"
                        prefWidth="120"/>

            </HBox>

        </VBox>

    </children>

</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.AfficherUsers"
      spacing="18"
      prefWidth="1500" 
      prefHeight="800"
      style="-fx-background-color: white;
             -fx-padding: 20;
             -fx-background-radius: 0;"
      stylesheets="@style.css"
      styleClass="root-pane">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Titre -->
    <Label text="👥 Liste des utilisateurs" 
           style="-fx-font-size: 24px; 
                  -fx-font-weight: bold;
                  -fx-text-fill: #1e3c72;
                  -fx-border-color: transparent transparent #1e3c72 transparent;
                  -fx-border-width: 0 0 2 0;
                  -fx-padding: 0 0 10 0;"/>
    
    <!-- Barre de recherche -->
    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 5 0 8 0;">
        <Label text="Rechercher :" 
               style="-fx-font-size: 13px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #1e3c72;"/>
        
        <TextField fx:id="searchField" 
                   promptText="🔍 Entrez votre recherche..." 
                   HBox.hgrow="ALWAYS"
                   style="-fx-background-radius: 18;
                          -fx-border-radius: 18;
                          -fx-border-color: #e0e0e0;
                          -fx-border-width: 1.2;
                          -fx-background-color: #f8f9fa;
                          -fx-padding: 8 12;
                          -fx-font-size: 12px;
                          -fx-focus-color: #1e3c72;
                          -fx-faint-focus-color: transparent;
                          -fx-pref-width: 280px;"/>
        
        <ComboBox fx:id="searchCriteriaCombo" 
                  style="-fx-background-radius: 12;
                         -fx-border-radius: 12;
                         -fx-border-color: #e0e0e0;
                         -fx-border-width: 1.2;
                         -fx-background-color: #f8f9fa;
                         -fx-padding: 5 8;
                         -fx-font-size: 12px;
                         -fx-focus-color: #1e3c72;
                         -fx-faint-focus-color: transparent;
                         -fx-pref-width: 140px;"/>
        
        <Button fx:id="searchButton" 
                text="🔍 Rechercher" 
                onAction="#handleSearch"
                style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #0f2b4f);
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-font-size: 12px;
                       -fx-background-radius: 18;
                       -fx-padding: 6 18;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, #1e3c72, 6, 0.2, 0, 2);"/>
        
        <Button fx:id="resetButton" 
                text="✖ Réinitialiser" 
                onAction="#resetSearch"
                style="-fx-background-color: #6c757d;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-font-size: 12px;
                       -fx-background-radius: 18;
                       -fx-padding: 6 18;
                       -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, #6c757d, 6, 0.2, 0, 2);"/>
    </HBox>
    
   
    
    <!-- Tableau des utilisateurs -->
    <TableView fx:id="tableUsers" 
               VBox.vgrow="ALWAYS"
               style="-fx-background-radius: 12;
                      -fx-border-radius: 12;
                      -fx-border-color: #e0e0e0;
                      -fx-border-width: 1;
                      -fx-background-color: white;">
        <columns>
            <TableColumn fx:id="colId" 
                         text="ID" 
                         prefWidth="45"
                         style="-fx-alignment: CENTER;
                                -fx-font-weight: bold;
                                -fx-font-size: 12px;"/>
            <TableColumn fx:id="colNom" 
                         text="Nom" 
                         prefWidth="100"
                         style="-fx-alignment: CENTER_LEFT;
                                -fx-font-size: 12px;"/>
            <TableColumn fx:id="colPrenom" 
                         text="Prénom" 
                         prefWidth="100"
                         style="-fx-alignment: CENTER_LEFT;
                                -fx-font-size: 12px;"/>
            <TableColumn fx:id="colEmail" 
                         text="Email" 
                         prefWidth="180"
                         style="-fx-alignment: CENTER_LEFT;
                                -fx-font-size: 12px;"/>
            <TableColumn fx:id="colTelephone" 
                         text="Téléphone" 
                         prefWidth="100"
                         style="-fx-alignment: CENTER;
                                -fx-font-size: 12px;"/>
            <TableColumn fx:id="colRole" 
                         text="Rôle" 
                         prefWidth="90"
                         style="-fx-alignment: CENTER;
                                -fx-font-size: 12px;"/>
            <TableColumn fx:id="colDateNaissance" 
                         text="Date Naiss." 
                         prefWidth="90"
                         style="-fx-alignment: CENTER;
                                -fx-font-size: 12px;"/>
            <TableColumn fx:id="colModifier" 
                         text="Modifier" 
                         prefWidth="70"
                         style="-fx-alignment: CENTER;
                                -fx-font-size: 12px;"/>
            <TableColumn fx:id="colSupprimer" 
                         text="Supprimer" 
                         prefWidth="70"
                         style="-fx-alignment: CENTER;
                                -fx-font-size: 12px;"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
    
    
    
</VBox>
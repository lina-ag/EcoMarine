<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.AjouterZone"
            prefWidth="1535"
            prefHeight="840"
            stylesheets="@style.css"
            styleClass="root-pane">

    <children>

        <VBox spacing="25"
              alignment="CENTER"
              style="-fx-background-color: white;
                     -fx-background-radius: 30;
                     -fx-border-radius: 30;
                     -fx-border-color: rgba(0,0,0,0.08);
                     -fx-border-width: 1.5;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 25, 0.2, 0, 8);"
              AnchorPane.topAnchor="50"
              AnchorPane.bottomAnchor="50"
              AnchorPane.leftAnchor="400"
              AnchorPane.rightAnchor="400">

            <padding>
                <Insets top="40" right="40" bottom="40" left="40" />
            </padding>

            <!-- En-tête avec icône -->
            <HBox alignment="CENTER" spacing="15">
                <children>
                    <ImageView fitWidth="40"
                               fitHeight="40"
                               preserveRatio="true">
                        <image>
                            <Image url="file:/C:/Users/WSI/Downloads/zone.png"/>
                        </image>
                    </ImageView>
                    <Label text="Ajouter une Zone Protégée"
                           style="-fx-font-size: 26px; 
                                  -fx-font-weight: 300;
                                  -fx-text-fill: #1e3c72;
                                  -fx-border-color: transparent transparent #1e3c72 transparent;
                                  -fx-border-width: 0 0 2 0;
                                  -fx-padding: 0 0 8 0;"/>
                </children>
            </HBox>

            <Label text="Remplissez les informations ci-dessous"
                   style="-fx-font-size: 14px;
                          -fx-text-fill: #666666;
                          -fx-font-weight: 300;
                          -fx-padding: 0 0 10 0;"/>

            <!-- Formulaire amélioré -->
            <GridPane hgap="20" vgap="20" alignment="CENTER">

                <!-- Ligne Nom Zone -->
                <Label text="Nom de la zone"
                       style="-fx-font-size: 14px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1e3c72;"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="tfNom"
                           promptText="Ex: Réserve marine de Korba"
                           prefWidth="300"
                           style="-fx-background-radius: 12;
                                  -fx-border-radius: 12;
                                  -fx-border-color: #e0e0e0;
                                  -fx-border-width: 1.5;
                                  -fx-background-color: #f8f9fa;
                                  -fx-padding: 12 15;
                                  -fx-font-size: 14px;
                                  -fx-focus-color: #1e3c72;
                                  -fx-faint-focus-color: transparent;"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <!-- Ligne Catégorie -->
                <Label text="Catégorie"
                       style="-fx-font-size: 14px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1e3c72;"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="tfCategorie"
                           promptText="Ex: Marine, Terrestre, Côtière"
                           prefWidth="300"
                           style="-fx-background-radius: 12;
                                  -fx-border-radius: 12;
                                  -fx-border-color: #e0e0e0;
                                  -fx-border-width: 1.5;
                                  -fx-background-color: #f8f9fa;
                                  -fx-padding: 12 15;
                                  -fx-font-size: 14px;
                                  -fx-focus-color: #1e3c72;
                                  -fx-faint-focus-color: transparent;"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <!-- Ligne Statut -->
                <Label text="Statut"
                       style="-fx-font-size: 14px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1e3c72;"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cbStatut"
                          prefWidth="300"
                          promptText="Sélectionnez un statut"
                          style="-fx-background-radius: 12;
                                 -fx-border-radius: 12;
                                 -fx-border-color: #e0e0e0;
                                 -fx-border-width: 1.5;
                                 -fx-background-color: #f8f9fa;
                                 -fx-padding: 5 10;
                                 -fx-font-size: 14px;
                                 -fx-focus-color: #1e3c72;
                                 -fx-faint-focus-color: transparent;"
                          GridPane.rowIndex="2"
                          GridPane.columnIndex="1"/>

            </GridPane>

            <!-- Bouton d'ajout amélioré -->
            <Button text="Ajouter la zone"
                    onAction="#ajouterZone"
                    prefHeight="55"
                    prefWidth="250"
                    >

                
            </Button>
            
            <Button text="Retour"
        onAction="#retournerGestionZones"
        prefWidth="120"/>

            

        </VBox>

    </children>

</AnchorPane>
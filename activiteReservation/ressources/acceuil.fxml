<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="controllers.AccueilController"
            stylesheets="@style.css"
            styleClass="root-pane"
            prefWidth="1500"
            prefHeight="800">

    <!-- SIDEBAR - Palette de couleurs originale -->
    <left>
        <VBox spacing="12" prefWidth="220" styleClass="sidebar">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>
            
            <!-- Logo -->
            <StackPane alignment="CENTER">
                <Region styleClass="header-background"/>
                <ImageView fitWidth="150"
                           fitHeight="150"
                           preserveRatio="true">
                    <Image url="file:/C:/Users/WSI/Downloads/logoEco.png"/>
                </ImageView>
            </StackPane>

            <Label text="ECOMARINE" styleClass="sidebar-title" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Accueil" styleClass="sidebar-subtitle" style="-fx-font-size: 16px; -fx-text-fill: white;"/>

            <Separator styleClass="sidebar-separator"/>

            <!-- Menu Principal -->
            <Label text="MENU PRINCIPAL" styleClass="sidebar-section-label" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <!-- SECTION 1 : GESTION ACTIVITÉS & RÉSERVATIONS -->
            <Label text="📊 MODULE COMPLET" 
                   styleClass="sidebar-section-label" 
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;">
                <VBox.margin>
                    <Insets top="20"/>
                </VBox.margin>
            </Label>

            <Button text="📊 Gestion Activités et Réservations"
                    onAction="#ouvrirModuleActivitesReservations"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"
                    />
            
            <!-- SECTION 2 : GESTION ZONES -->
            <Label text="🗺️ GESTION ZONES"
                   styleClass="sidebar-section-label"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;">
                <VBox.margin>
                    <Insets top="15"/>
                </VBox.margin>
            </Label>

            <Button text="🗺️ Gestion Zones"
                    onAction="#ouvrirGestionZones"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"/>


            <!-- SECTION 4 : PROFIL ET DÉCONNEXION -->
            <Label text="👤 MON COMPTE"
                   styleClass="sidebar-section-label"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;">
                <VBox.margin>
                    <Insets top="15"/>
                </VBox.margin>
            </Label>

            <Button text="👤 Mon Profil"
                    onAction="#ouvrirProfil"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"/>

            
            <Button text="📅 Mes Réservations"
                    onAction="#ouvrirModuleActivitesReservations"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"/>
            
            <Button text="🚪 Déconnexion"
                    onAction="#deconnexion"
                    maxWidth="Infinity"
                    styleClass="sidebar-button"
                    style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
>>>>>>> branch 'master' of https://github.com/lina-ag/EcoMarine.git

            <Region VBox.vgrow="ALWAYS"/>

        </VBox>
    </left>

    <!-- CONTENU PRINCIPAL -->
    <center>
        <StackPane styleClass="acceuil-center">
            <VBox alignment="CENTER" spacing="25">
                <padding>
                    <Insets top="30" right="30" bottom="30" left="30"/>
                </padding>
                
                <!-- Header avec date et informations utilisateur -->
                <HBox alignment="CENTER" spacing="20" maxWidth="Infinity">
                    <Label fx:id="lblDateActuelle" 
                           style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-weight: 500;"/>
                    <Label text="•" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
                    <Label fx:id="lblMessageBienvenue" 
                           text="Bienvenue sur EcoMarine ! 🌊"
                           style="-fx-font-size: 14px; -fx-text-fill: #1e3c72; -fx-font-weight: 500;"/>
                </HBox>
                
                <!-- Nom utilisateur et rôle -->
                <VBox alignment="CENTER" spacing="5">
                    <Label fx:id="lblNomUtilisateur" 
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e3c72;"/>
                    <Label fx:id="lblRole" 
                           style="-fx-font-size: 14px; -fx-text-fill: #0284c7;"/>
                </VBox>
                
                <Label text="Votre solution de gestion touristique intégrée"
                       style="-fx-font-size: 18px; -fx-text-fill: #0284c7;"/>
                
                <Separator styleClass="acceuil-separator" maxWidth="350"/>
                
                <!-- Cartes des 3 fonctionnalités principales avec animations -->
                <HBox fx:id="cardsContainer" spacing="20" alignment="CENTER">
                    
                    <!-- Carte Activités & Réservations -->
                    <VBox styleClass="acceuil-card" 
                          onMouseClicked="#ouvrirModuleActivitesReservations"
                          style="-fx-cursor: hand;">
                        <Label text="📊" styleClass="acceuil-card-icon"/>
                        <Label text="Activités" styleClass="acceuil-card-title"/>
                        <Label text="Réservations" styleClass="acceuil-card-title"/>
                        <Label text="Gérer les activités et réservations" styleClass="acceuil-card-desc"/>
                    </VBox>
                    
                    <!-- Carte Zones -->
                    <VBox styleClass="acceuil-card" 
                          onMouseClicked="#ouvrirGestionZones"
                          style="-fx-cursor: hand;">
                        <Label text="🗺️" styleClass="acceuil-card-icon"/>
                        <Label text="Zones" styleClass="acceuil-card-title"/>
                        <Label text="Protégées" styleClass="acceuil-card-title"/>
                        <Label text="Gérer les zones protégées" styleClass="acceuil-card-desc"/>
                    </VBox>
                    
                    
                    
                </HBox>
                
                <!-- Message d'instruction -->
                <Label text="Sélectionnez une option dans le menu ou cliquez sur une carte"
                       style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-font-style: italic;"/>
                
                <!-- Statistiques rapides (optionnel) -->
                <HBox spacing="30" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="📊" style="-fx-font-size: 24px;"/>
                        <Label text="Activités" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                        <Label fx:id="lblTotalActivites" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e3c72;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="5">
                        <Label text="🗺️" style="-fx-font-size: 24px;"/>
                        <Label text="Zones" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                        <Label fx:id="lblTotalZones" text="0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e3c72;"/>
                    </VBox>
                </HBox>
                
                <!-- Conseil du jour -->
                <VBox alignment="CENTER" spacing="8" style="-fx-padding: 10 0 0 0;">
                    <Label text="💡 Conseil du jour" 
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1e3c72;"/>
                    <Label text="Utilisez la barre de recherche pour retrouver rapidement vos données"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-font-style: italic;"/>
                </VBox>
                
            </VBox>
        </StackPane>
    </center>

</BorderPane>
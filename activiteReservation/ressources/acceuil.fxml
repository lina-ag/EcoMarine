<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="controllers.AccueilController"
            stylesheets="@style.css"
            styleClass="root-pane"
            prefWidth="1400"
            prefHeight="820">

    <!-- ===== SIDEBAR ===== -->
    <left>
        <VBox spacing="8" prefWidth="210" styleClass="sidebar">
            <padding><Insets top="20" right="10" bottom="20" left="10"/></padding>

            <!-- Logo -->
            <StackPane alignment="CENTER">
                <Region styleClass="header-background"/>
                <ImageView fitWidth="120" fitHeight="120" preserveRatio="true">
                    <Image url="file:/C:/Users/WSI/Downloads/logoEco.png"/>
                </ImageView>
            </StackPane>

            <Label text="ECOMARINE" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white; -fx-alignment: center;"/>
            <Label text="Accueil" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.7); -fx-alignment: center;"/>

            <Separator styleClass="sidebar-separator"/>

            <Label text="MENU PRINCIPAL" styleClass="sidebar-section-label"/>

            <Label text="Gestion Activite et Reservation" styleClass="sidebar-section-label" 
       style="-fx-font-size: 16px; -fx-font-weight: none; -fx-text-fill: white;">
                <VBox.margin><Insets top="10"/></VBox.margin>
            </Label>
           <Button onAction="#ouvrirModuleActivitesReservations"
        maxWidth="Infinity" styleClass="sidebar-button">
    <graphic>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <ImageView fitWidth="25" fitHeight="25">
                <image>
                    <Image url="file:/C:/Users/WSI/Downloads/reserve.png"/>
                </image>
            </ImageView>
            <Label text="Gestion Activités et Réservations" style="-fx-text-fill: white;"/>
        </HBox>
    </graphic>
</Button>

            <Label text="GESTION ZONES" styleClass="sidebar-section-label" 
       style="-fx-font-size: 16px; -fx-font-weight: none; -fx-text-fill: white;">
                <VBox.margin><Insets top="10"/></VBox.margin>
            </Label>
            <Button onAction="#ouvrirGestionZones"
        maxWidth="Infinity"
        styleClass="sidebar-button">
    <graphic>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <ImageView fitWidth="30" fitHeight="30">
                <image>
                    <Image url="file:/C:/Users/WSI/Downloads/gestionZone.png"/> 
                </image>
            </ImageView>
            <Label text="Gestion Zones" style="-fx-text-fill: white;"/>
        </HBox>
    </graphic>
</Button>
             <!-- ============================================ -->
            <!-- 🐋 FAUNE MARINE - YOUR NEW SECTION -->
            <!-- ============================================ -->
            <Label text="FAUNE MARINE" styleClass="sidebar-section-label" 
       style="-fx-font-size: 16px; -fx-font-weight: none; -fx-text-fill: white;">
    <VBox.margin>
        <Insets top="15"/>
    </VBox.margin>
</Label>

<Button onAction="#ouvrirFauneMarine"
        maxWidth="Infinity"
        styleClass="sidebar-button">
    <graphic>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <ImageView fitWidth="25" fitHeight="25">
                <image>
                    <Image url="file:/C:/Users/WSI/Downloads/fauneMarine.png"/> <!-- ton icône whale.png -->
                </image>
            </ImageView>
            <Label text="Gestion Faune Marine" style="-fx-text-fill: white;"/>
        </HBox>
    </graphic>
</Button>
            <!-- ============================================ -->


            


            <Region VBox.vgrow="ALWAYS"/>

            <Button text="🚪 Déconnexion"
                    onAction="#deconnexion"
                    maxWidth="Infinity"
                    style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold; -fx-padding: 10 15;"/>
        </VBox>
    </left>

    <!-- ===== CONTENU PRINCIPAL ===== -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="accueil-scroll" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="16" styleClass="accueil-main">
                <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

                <!-- ===== TOPBAR ===== -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblDateActuelle" styleClass="accueil-topbar-date"/>
                        <Label fx:id="lblMessageBienvenue" styleClass="accueil-topbar-welcome"/>
                    </VBox>
                    <!-- Avatar + nom -->
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <VBox alignment="CENTER_RIGHT" spacing="2">
                            <Label fx:id="lblNomUtilisateur" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 3, 0.2, 0, 1);"/>
                            <Label fx:id="lblRole" style="-fx-font-size: 12px; -fx-text-fill: rgba(0,0,0,0.8);"/>
                        </VBox>
                        <StackPane styleClass="accueil-avatar">
                            <Label fx:id="lblAvatar" text="LA" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        </StackPane>
                    </HBox>
                </HBox>

                <!-- ===== KPI CARDS ===== -->
                <HBox spacing="14">
                    <!-- KPI Activités -->
                    <VBox styleClass="accueil-kpi-card, kpi-blue-border" HBox.hgrow="ALWAYS" spacing="4">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="📊" style="-fx-font-size: 22px;"/>
                            <Label text="Activités" styleClass="accueil-kpi-label"/>
                        </HBox>
                        <Label fx:id="lblTotalActivites" text="0" styleClass="accueil-kpi-value"/>
                        <Label text="ce mois" styleClass="accueil-kpi-sub"/>
                        <StackPane styleClass="accueil-kpi-bar-bg">
                            <StackPane fx:id="barActivites" styleClass="accueil-kpi-bar-fill, kpi-fill-blue" alignment="CENTER_LEFT"/>
                        </StackPane>
                    </VBox>

                    <!-- KPI Réservations -->
                    <VBox styleClass="accueil-kpi-card, kpi-green-border" HBox.hgrow="ALWAYS" spacing="4">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="📅" style="-fx-font-size: 22px;"/>
                            <Label text="Réservations" styleClass="accueil-kpi-label"/>
                        </HBox>
                        <Label fx:id="lblTotalReservations" text="0" styleClass="accueil-kpi-value"/>
                        <Label text="total" styleClass="accueil-kpi-sub"/>
                        <StackPane styleClass="accueil-kpi-bar-bg">
                            <StackPane fx:id="barReservations" styleClass="accueil-kpi-bar-fill, kpi-fill-green" alignment="CENTER_LEFT"/>
                        </StackPane>
                    </VBox>

                    <!-- KPI Zones -->
                    <VBox styleClass="accueil-kpi-card, kpi-orange-border" HBox.hgrow="ALWAYS" spacing="4">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="🗺️" style="-fx-font-size: 22px;"/>
                            <Label text="Zones surveillées" styleClass="accueil-kpi-label"/>
                        </HBox>
                        <Label fx:id="lblTotalZones" text="0" styleClass="accueil-kpi-value"/>
                        <Label text="zones actives" styleClass="accueil-kpi-sub"/>
                        <StackPane styleClass="accueil-kpi-bar-bg">
                            <StackPane fx:id="barZones" styleClass="accueil-kpi-bar-fill, kpi-fill-orange" alignment="CENTER_LEFT"/>
                        </StackPane>
                    </VBox>

                    <!-- KPI Tâches -->
                    <VBox styleClass="accueil-kpi-card, kpi-purple-border" HBox.hgrow="ALWAYS" spacing="4">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="📋" style="-fx-font-size: 22px;"/>
                            <Label text="Tâches" styleClass="accueil-kpi-label"/>
                        </HBox>
                        <Label fx:id="lblTotalTaches" text="0" styleClass="accueil-kpi-value"/>
                        <Label text="en cours" styleClass="accueil-kpi-sub"/>
                        <StackPane styleClass="accueil-kpi-bar-bg">
                            <StackPane fx:id="barTaches" styleClass="accueil-kpi-bar-fill, kpi-fill-purple" alignment="CENTER_LEFT"/>
                        </StackPane>
                    </VBox>
                </HBox>

                <!-- ===== LIGNE 2 : MODULES + TIMELINE ===== -->
                <HBox spacing="14">

                    <!-- Modules (3 cartes verticales) -->
                    <VBox spacing="12" prefWidth="340">
                        <Label text="Accès rapide" styleClass="accueil-section-title"/>

                        <!-- Carte Activités & Réservations -->
                        <HBox styleClass="accueil-module-card" onMouseClicked="#ouvrirModuleActivitesReservations" style="-fx-cursor: hand;" spacing="14" alignment="CENTER_LEFT">
                            <StackPane styleClass="accueil-module-icon-bg, mod-green">
                                <Label text="🏄" style="-fx-font-size: 20px;"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Activités &amp; Réservations" styleClass="accueil-module-title"/>
                                <Label text="Gérer les activités et réservations" styleClass="accueil-module-desc"/>
                            </VBox>
                            <Label fx:id="badgeActivites" text="0" styleClass="accueil-module-badge"/>
                        </HBox>

                        <!-- Carte Tâches -->
                        <HBox styleClass="accueil-module-card" style="-fx-cursor: hand;" spacing="14" alignment="CENTER_LEFT">
                            <StackPane styleClass="accueil-module-icon-bg, mod-blue">
                                <Label text="📋" style="-fx-font-size: 20px;"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Tâches Utilisateur" styleClass="accueil-module-title"/>
                                <Label text="Suivi des tâches assignées" styleClass="accueil-module-desc"/>
                            </VBox>
                            <Label fx:id="badgeTaches" text="0" styleClass="accueil-module-badge"/>
                        </HBox>

                        <!-- Carte Zones -->
                        <HBox styleClass="accueil-module-card" onMouseClicked="#ouvrirGestionZones" style="-fx-cursor: hand;" spacing="14" alignment="CENTER_LEFT">
                            <StackPane styleClass="accueil-module-icon-bg, mod-orange">
                                <Label text="🗺️" style="-fx-font-size: 20px;"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Gestion Zones Surveillées" styleClass="accueil-module-title"/>
                                <Label text="Zones protégées de Kuriat" styleClass="accueil-module-desc"/>
                            </VBox>
                            <Label fx:id="badgeZones" text="0" styleClass="accueil-module-badge, badge-alert"/>
                        </HBox>
                    </VBox>

                    <!-- Timeline activité récente -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="Activité récente" styleClass="accueil-section-title"/>
                        <VBox styleClass="accueil-card-box" spacing="12" VBox.vgrow="ALWAYS">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                            <HBox styleClass="accueil-tl-item" spacing="10" alignment="CENTER_LEFT">
                                <Region styleClass="accueil-tl-dot, tl-green"/>
                                <VBox spacing="1">
                                    <Label text="Nouvelle réservation — Plongée sous-marine" styleClass="accueil-tl-text"/>
                                    <Label text="il y a 12 min" styleClass="accueil-tl-time"/>
                                </VBox>
                            </HBox>
                            <Separator opacity="0.4"/>
                            <HBox styleClass="accueil-tl-item" spacing="10" alignment="CENTER_LEFT">
                                <Region styleClass="accueil-tl-dot, tl-blue"/>
                                <VBox spacing="1">
                                    <Label text="Activité ajoutée — Kayak côtier" styleClass="accueil-tl-text"/>
                                    <Label text="il y a 1h" styleClass="accueil-tl-time"/>
                                </VBox>
                            </HBox>
                            <Separator opacity="0.4"/>
                            <HBox styleClass="accueil-tl-item" spacing="10" alignment="CENTER_LEFT">
                                <Region styleClass="accueil-tl-dot, tl-orange"/>
                                <VBox spacing="1">
                                    <Label text="Tâche assignée — Rapport Zone B" styleClass="accueil-tl-text"/>
                                    <Label text="il y a 3h" styleClass="accueil-tl-time"/>
                                </VBox>
                            </HBox>
                            <Separator opacity="0.4"/>
                            <HBox styleClass="accueil-tl-item" spacing="10" alignment="CENTER_LEFT">
                                <Region styleClass="accueil-tl-dot, tl-red"/>
                                <VBox spacing="1">
                                    <Label text="Alerte Zone Nord — activité suspecte" styleClass="accueil-tl-text"/>
                                    <Label text="hier" styleClass="accueil-tl-time"/>
                                </VBox>
                            </HBox>
                            <Separator opacity="0.4"/>
                            <HBox styleClass="accueil-tl-item" spacing="10" alignment="CENTER_LEFT">
                                <Region styleClass="accueil-tl-dot, tl-green"/>
                                <VBox spacing="1">
                                    <Label text="Réservation confirmée — Snorkeling" styleClass="accueil-tl-text"/>
                                    <Label text="hier" styleClass="accueil-tl-time"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- ===== LIGNE 3 : CARTE KURIAT + CONSEIL ===== -->
                <HBox spacing="14">

                    <!-- Mini carte Kuriat Island -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="Kuriat Island — Zones actives" styleClass="accueil-section-title"/>
                        <VBox styleClass="accueil-card-box, accueil-map-box" alignment="CENTER" VBox.vgrow="ALWAYS">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                            <Label text="🌊 Monastir, Tunisie — Zone de recherche marine"
                                   style="-fx-font-size: 13px; -fx-text-fill: #0284c7; -fx-font-weight: 600;"/>
                            <HBox spacing="20" alignment="CENTER" style="-fx-padding: 16 0 10 0;">
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="🟢" style="-fx-font-size: 20px;"/>
                                    <Label text="Zone A" style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #059669;"/>
                                    <Label text="Active" style="-fx-font-size: 10px; -fx-text-fill: #64748b;"/>
                                </VBox>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="🟡" style="-fx-font-size: 20px;"/>
                                    <Label text="Zone B" style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #d97706;"/>
                                    <Label text="Surveillance" style="-fx-font-size: 10px; -fx-text-fill: #64748b;"/>
                                </VBox>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="🔴" style="-fx-font-size: 20px;"/>
                                    <Label text="Zone Nord" style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #dc2626;"/>
                                    <Label text="Alerte" style="-fx-font-size: 10px; -fx-text-fill: #64748b;"/>
                                </VBox>
                                <VBox alignment="CENTER" spacing="4">
                                    <Label text="🔵" style="-fx-font-size: 20px;"/>
                                    <Label text="Zone C" style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #0284c7;"/>
                                    <Label text="Repos" style="-fx-font-size: 10px; -fx-text-fill: #64748b;"/>
                                </VBox>
                            </HBox>
                            <Label text="2 alertes actives — intervention recommandée"
                                   style="-fx-font-size: 11px; -fx-text-fill: #dc2626; -fx-font-weight: 600; -fx-background-color: #fee2e2; -fx-background-radius: 10; -fx-padding: 4 12;"/>
                        </VBox>
                    </VBox>

                    <!-- Conseil du jour + bienvenue -->
                    <VBox spacing="12" prefWidth="320">
                        <Label text="Infos &amp; Conseils" styleClass="accueil-section-title"/>
                        <VBox styleClass="accueil-card-box" spacing="14" VBox.vgrow="ALWAYS">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="💡" style="-fx-font-size: 22px;"/>
                                <VBox spacing="3">
                                    <Label text="Conseil du jour" style="-fx-font-weight: 700; -fx-text-fill: #1e3c72; -fx-font-size: 13px;"/>
                                    <Label text="Utilisez la barre de recherche pour retrouver rapidement vos données"
                                           style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-wrap-text: true; -fx-max-width: 220;"/>
                                </VBox>
                            </HBox>

                            <Separator opacity="0.4"/>

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="🔬" style="-fx-font-size: 22px;"/>
                                <VBox spacing="3">
                                    <Label text="Recherche marine" style="-fx-font-weight: 700; -fx-text-fill: #1e3c72; -fx-font-size: 13px;"/>
                                    <Label text="Kuriat Island abrite une biodiversité exceptionnelle à préserver"
                                           style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-wrap-text: true; -fx-max-width: 220;"/>
                                </VBox>
                            </HBox>

                            <Separator opacity="0.4"/>

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="📊" style="-fx-font-size: 22px;"/>
                                <VBox spacing="3">
                                    <Label text="Tableau de bord" style="-fx-font-weight: 700; -fx-text-fill: #1e3c72; -fx-font-size: 13px;"/>
                                    <Label text="Accédez aux KPIs détaillés via le module Activités"
                                           style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-wrap-text: true; -fx-max-width: 220;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.AjouterReservation"
            prefWidth="500"
            prefHeight="450"
            stylesheets="@style.css">

    <children>

        <VBox spacing="15"
              alignment="CENTER"
              AnchorPane.topAnchor="20"
              AnchorPane.bottomAnchor="20"
              AnchorPane.leftAnchor="40"
              AnchorPane.rightAnchor="40">

            <Label text="Ajouter une Réservation"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />

            <GridPane hgap="10" vgap="15">

                <Label text="Nom :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="tfNom" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Email :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="tfEmail" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Nb Personnes :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="tfNombre_personnes" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Date :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <DatePicker fx:id="dpDate" prefWidth="200"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="ID Activité :" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="tfIdActivite" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            </GridPane>

            <Button text="Ajouter"
                    onAction="#ajouterReservation"
                    style="-fx-background-color: #6a0dad; -fx-text-fill: white; -fx-font-weight: bold;"
                    prefWidth="150"/>

        </VBox>

    </children>

</AnchorPane>
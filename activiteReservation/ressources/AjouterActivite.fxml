<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.AjouterActivite"
            prefWidth="500"
            prefHeight="450"
            stylesheets="@style.css">

    <children>

        <VBox spacing="15"
              alignment="CENTER"
              AnchorPane.topAnchor="20"
              AnchorPane.bottomAnchor="20"
              AnchorPane.leftAnchor="40"
              AnchorPane.rightAnchor="40">

            <Label text="Ajouter une Activité Écologique"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />

            <GridPane hgap="10" vgap="15">

                <!-- Nom -->
                <Label text="Nom :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="tfNom"
                           promptText="Entrer le nom de l'activité"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"
                           prefWidth="250"/>

                <!-- Description -->
                <Label text="Description :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="tfDescription"
                           promptText="Entrer la description"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <!-- Date avec DatePicker -->
                <Label text="Date :" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <HBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                    <DatePicker fx:id="datePicker" 
                                prefWidth="220"
                                promptText="Sélectionner une date"/>
                    <Label text="" style="-fx-font-size: 18px; -fx-padding: 5 0 0 0;"/>
                </HBox>

                <!-- Capacité -->
                <Label text="Capacité :" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="tfCapacite"
                           promptText="Entrer la capacité"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="1"/>

            </GridPane>

            <Button text="Ajouter"
                    onAction="#ajouterActivite"
                    style="-fx-background-color: #6a0dad; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;"
                    prefWidth="150"
                    prefHeight="40"/>

        </VBox>

    </children>

</AnchorPane>
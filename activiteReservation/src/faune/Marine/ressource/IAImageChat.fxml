<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="faune.Marine.controllers.IAImageChatController"
       stylesheets="@style.css"
       styleClass="root-pane"
      style="-fx-background-color: #F5F5F5; -fx-padding: 10;">
    
    <!-- ==================== EN-TÊTE SANS MODÈLE ==================== -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: white; -fx-background-radius: 10;">
        <Label text="🤖" style="-fx-font-size: 32px;"/>
        <VBox>
            <Label text="Assistant IA" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="Discutez avec l'IA après l'analyse" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        
        <!-- SUPPRIMÉ : La ComboBox du modèle a été retirée -->
        
        <Button fx:id="btnEffacer" text="🔄 Effacer" onAction="#effacerChat"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 5;"/>
    </HBox>
    
    <!-- ==================== ZONE DE CHAT ==================== -->
    <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS" 
                style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox fx:id="chatContainer" spacing="5" style="-fx-padding: 5;">
            <!-- Messages ajoutés dynamiquement -->
        </VBox>
    </ScrollPane>
    
    <!-- ==================== ZONE DE SAISIE ==================== -->
    <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: white; -fx-background-radius: 10;">
        <TextField fx:id="txtMessage" promptText="Tape ta question..." HBox.hgrow="ALWAYS"
                   style="-fx-background-radius: 20; -fx-padding: 8 15;"/>
        <Button fx:id="btnEnvoyer" text="📤 Envoyer" onAction="#envoyerMessage"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;"/>
    </HBox>
    
    <!-- ==================== STATUT (optionnel) ==================== -->
    <Label fx:id="lblStatut" text="" 
           style="-fx-text-fill: #666; -fx-font-size: 11px; -fx-padding: 0 5; -fx-alignment: center-right;"/>
    
</VBox>